generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model City {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  regionName      String?
  createdAt       DateTime @default(now())
  events          Event[]
  members         Member[]
  regionalLeaders User[]   @relation("RegionalLeaders")
  users           User[]   @relation("UserCities")
}

model Member {
  id        String          @id @default(cuid())
  name      String
  email     String          @unique
  phone     String
  company   String?
  industry  String?
  status    String          @default("Ativo")
  createdAt DateTime        @default(now())
  cityId    String
  city      City            @relation(fields: [cityId], references: [id])
  payments  MemberPayment[]
}

model MemberPayment {
  id          String   @id @default(cuid())
  amount      Float
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  phone        String
  password     String
  role         String     @default("APOIADOR")
  createdAt    DateTime   @default(now())
  resetExpires DateTime?
  resetToken   String?
  logs         AuditLog[]
  ledCities    City[]     @relation("RegionalLeaders")
  cities       City[]     @relation("UserCities")
}

model Event {
  id              String     @id @default(cuid())
  title           String
  description     String?
  date            DateTime
  location        String
  capacity        Int        @default(0)
  price           Float      @default(0)
  status          String     @default("DRAFT")
  createdAt       DateTime   @default(now())
  financialLocked Boolean    @default(false)
  reportSentAt    DateTime?
  cityId          String
  bannerUrl       String?
  attendees       Attendee[]
  city            City       @relation(fields: [cityId], references: [id])
  finances        Finance[]
}

model Attendee {
  id              String   @id @default(cuid())
  name            String
  phone           String
  email           String
  company         String?
  industry        String
  interests       String[]
  paymentStatus   String   @default("Pendente")
  presenceStatus  String   @default("Pendente")
  createdAt       DateTime @default(now())
  eventId         String
  paymentProofUrl String?
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([email, eventId])
}

model Finance {
  id          String   @id @default(cuid())
  type        String
  amount      Float
  description String
  notes       String?
  receiptUrl  String?
  createdAt   DateTime @default(now())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}
